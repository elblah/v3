"""
Request Transform Plugin

Transforms request JSON for specific providers (e.g., Alibaba/Qwen cache control).
Activated by AICODER_TRANSFORM_REQUEST env var (e.g., "alibaba").

Matches sample-qwen.json structure exactly:
- "system" as separate key with array format and cache_control
- "messages" without system role
- Content as {"type": "text", ...}, {"type": "thinking", ...}, {"type": "tool_use", ...} blocks
- tool calls as tool_use blocks (not separate tool_calls array)
- tool results as user message with tool_result block
- cache_control on last text/tool_use block only
"""

import os
import json
import uuid
from aicoder.core.config import Config


def create_plugin(ctx):
    """Request transform plugin"""

    transform_type = os.environ.get("AICODER_TRANSFORM_REQUEST", "")
    if Config.debug():
        print(f"{Config.colors['dim']}[+] transform_request plugin loaded (mode: {transform_type}){Config.colors['reset']}")

    def transform_request(data, endpoint=None):
        """Transform request data based on AICODER_TRANSFORM_REQUEST"""
        if transform_type == "alibaba":
            return transform_alibaba(data)
        return data

    ctx.register_hook("transform_request", transform_request)


def random_id():
    """Generate random ID like toolu_xxx format"""
    return uuid.uuid4().hex[:16]


def transform_alibaba(data):
    """Transform for Alibaba/Qwen cache format - matches sample-qwen.json structure"""
    messages = data.get("messages", [])
    if not messages:
        return data

    # Move system message to separate "system" key (like sample-qwen.json)
    system_msgs = [m for m in messages if m.get("role") == "system"]
    if system_msgs:
        system_content = system_msgs[0].get("content", "")
        data["messages"] = [m for m in messages if m.get("role") != "system"]
        data["system"] = [{
            "type": "text",
            "text": system_content,
            "cache_control": {"type": "ephemeral"}
        }]

    # Transform each message to match sample-qwen.json structure
    for msg in data.get("messages", []):
        content = msg.get("content", "")
        reasoning = msg.get("reasoning_content") or msg.get("reasoning") or msg.get("reasoning_text")
        tool_calls = msg.get("tool_calls", [])

        new_content = []

        # Handle reasoning -> thinking block
        if reasoning:
            new_content.append({
                "type": "thinking",
                "thinking": reasoning,
                "signature": ""
            })
            # Remove reasoning fields
            for field in ["reasoning_content", "reasoning", "reasoning_text"]:
                msg.pop(field, None)

        # Handle tool_calls -> tool_use blocks
        if tool_calls:
            for tc in tool_calls:
                func = tc.get("function", {})
                new_content.append({
                    "type": "tool_use",
                    "id": tc.get("id", "toolu_" + random_id()),
                    "name": func.get("name", ""),
                    "input": json.loads(func.get("arguments", "{}") or "{}"),
                    "cache_control": {"type": "ephemeral"}
                })
            msg.pop("tool_calls", None)

        # Handle regular text content
        if isinstance(content, str) and content:
            new_content.append({"type": "text", "text": content})
        elif isinstance(content, list):
            for block in content:
                if isinstance(block, dict):
                    if block.get("type") == "text":
                        new_content.append(block)

        # Set final content
        if new_content:
            msg["content"] = new_content

    # Transform tool results (role: tool -> role: user with tool_result)
    for msg in data.get("messages", []):
        if msg.get("role") == "tool":
            msg["role"] = "user"
            tool_call_id = msg.pop("tool_call_id", "")
            content = msg.get("content", "")
            msg["content"] = [{
                "type": "tool_result",
                "tool_use_id": tool_call_id,
                "content": content if isinstance(content, str) else "",
                "cache_control": {"type": "ephemeral"}
            }]
            msg.pop("tool_call_id", None)

    # Add cache_control to last message's last block
    last_msgs = data.get("messages", [])
    if last_msgs:
        last_msg = last_msgs[-1]
        content = last_msg.get("content", [])
        if isinstance(content, list) and content:
            # Add cache_control to last block that isn't tool-approval-request/response
            for block in reversed(content):
                if isinstance(block, dict) and block.get("type") in ("text", "tool_use", "tool_result"):
                    block["cache_control"] = {"type": "ephemeral"}
                    break

    return data